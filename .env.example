# Get this from: Neon Console → your project → Connection string
# Make sure "Connection pooling" is ON (use the pooler URL shown in the dialog)
DATABASE_URL=postgresql://neondb_owner:your-password@your-host-pooler.neon.tech/neondb?sslmode=require

# Better Auth requires a secret for session signing
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars

# Admin password for accessing the admin panel
NEXT_PUBLIC_ADMIN_PASSWORD=exp.admin
